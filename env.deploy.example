# Copy to .env in the repo root (same folder as docker-compose.prod.yml):
#   cp env.deploy.example .env
# Edit secrets, then:
#   docker compose -f docker-compose.prod.yml --env-file .env up --build -d

# --- PostgreSQL (docker-compose service `db`) ---
POSTGRES_DB=erpdb
POSTGRES_USER=erpuser
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# --- Backend Prisma (must match POSTGRES_*; host is service name `db`) ---
DATABASE_URL=postgresql://erpuser:change-me-to-a-long-random-password@db:5432/erpdb

# --- Auth (required) ---
JWT_SECRET=change-me-to-at-least-32-random-bytes
JWT_EXPIRES_IN=7d

# --- CORS: browser origin(s) allowed to call the API when not using same-origin nginx.
# Comma-separated, or * for any (less strict). Same host + nginx proxy → often unnecessary.
CORS_ORIGIN=https://your-domain.com

# Public self-service registration (keep false in production unless intended)
ALLOW_PUBLIC_REGISTRATION=false

# Host port mapped to backend (optional; for debugging or direct API access)
BACKEND_PORT=3000

# Nginx (SPA) host port — default 80
FRONTEND_PORT=80

# Baked into the frontend bundle: same-origin /api (nginx proxies to backend). Override only if unusual.
VITE_API_URL=/api

# Access logs on stdout
HTTP_LOGS=false
