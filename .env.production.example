POSTGRES_USER=wareflow
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=wareflow

# Points to the db service inside Docker
DATABASE_URL=postgresql://wareflow:change-me-strong@db:5432/wareflow

JWT_SECRET=change-me-very-strong
JWT_EXPIRES_IN=7d

PORT=4000
NODE_ENV=production

# Your production domain (no trailing slash)
CORS_ORIGIN=https://wareflow.waseemuddin.me

POSTGRES_DB=erpdb
POSTGRES_USER=erpuser
POSTGRES_PASSWORD=replace-with-strong-password

# For docker-compose local postgres service:
DATABASE_URL=postgresql://erpuser:replace-with-strong-password@db:5432/erpdb

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
ALLOW_PUBLIC_REGISTRATION=false
HTTP_LOGS=false

# Your public app domain used by browser
CORS_ORIGIN=https://your-domain.com

