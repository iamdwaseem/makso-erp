# Local dev: leave unset → same-origin /api → Vite proxy (no CORS).
# LAN / device testing: use your machine IP, not localhost, e.g. VITE_API_URL=http://192.168.1.10:4000/api
#
# Production (Docker/nginx): use VITE_API_URL=/api so the browser calls https://your-domain/api (same origin).
# Never bake http://localhost:4000 into a production build — it will fail CORS on DigitalOcean etc.
# VITE_API_URL=/api

# Feature flags
# Set to "true" to expose GRN Print Invoice UI/routes.
VITE_ENABLE_PRINT_INVOICE=false
