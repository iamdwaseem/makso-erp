{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch --env-file=.env src/server.ts",
    "build": "tsc --outDir dist",
    "start": "prisma migrate deploy && node dist/src/server.js",
    "start:tsx": "prisma migrate deploy && npx tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/sku.test.ts tests/role.middleware.unit.test.ts",
    "test:integration": "vitest run tests/inventory.test.ts tests/history.filters.test.ts tests/transfer.test.ts",
    "test:security": "vitest run tests/auth.test.ts tests/security.authorization.test.ts",
    "test:db": "vitest run tests/db.correctness.test.ts",
    "test:concurrency": "vitest run tests/concurrency.stock.test.ts",
    "test:smoke": "vitest run tests/smoke.api.test.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:security && npm run test:db && npm run test:concurrency && npm run test:smoke",
    "test:load": "tsx tests/load/run-load-tests.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed:makso": "tsx prisma/seed-makso.ts",
    "seed:demo": "tsx prisma/seed.ts",
    "seed:current": "tsx prisma/seed-current.ts",
    "seed:inventory": "tsx src/seeds/inventory.seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "autocannon": "^8.0.0",
    "prisma": "^5.10.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "seed": "tsx prisma/seed-makso.ts"
  }
}
